<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" styleClass="root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.ticketflow.ui.controller.AdminDashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="navbar">
            <padding>
                <Insets bottom="15" left="25" right="25" top="15" />
            </padding>
            <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="TicketFlow Admin" />
            <HBox HBox.hgrow="ALWAYS" />

            <Button onAction="#handleLogout" styleClass="button-danger" text="Logout" />
        </HBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" style="-fx-background-color: transparent;">

            <Tab text="Gestione Cinema">
                <VBox spacing="20.0">
                    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

                    <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0); -fx-padding: 15;" VBox.vgrow="ALWAYS">
                        <Label styleClass="label-subtitle" text="Elenco Cinema" />
                        <TableView fx:id="cinemaTable" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                            <columns>
                                <TableColumn fx:id="colIdCinema" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="colNomeCinema" prefWidth="200.0" text="Nome" />
                                <TableColumn fx:id="colIndirizzoCinema" prefWidth="300.0" text="Indirizzo" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                    </VBox>

                    <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0); -fx-padding: 20;">
                        <Label style="-fx-font-weight: bold;" text="Nuovo Cinema:" />
                        <TextField fx:id="txtNomeCinema" promptText="Nome Cinema" prefWidth="200"/>
                        <TextField fx:id="txtIndirizzoCinema" promptText="Indirizzo" HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleAggiungiCinema" styleClass="button-primary" text="Aggiungi" />
                        <Button onAction="#handleRimuoviCinema" styleClass="button-danger" text="Rimuovi Selezionato" />
                    </HBox>
                </VBox>
            </Tab>

            <Tab text="Catalogo Film">
                <HBox spacing="20.0">
                    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

                    <VBox prefWidth="320.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);">
                        <Label styleClass="label-subtitle" text="Nuovo Film" />
                        <VBox spacing="5">
                            <Label text="Titolo" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                            <TextField fx:id="txtTitoloFilm" promptText="Es. Interstellar" />
                        </VBox>
                        <VBox spacing="5">
                            <Label text="Genere" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                            <TextField fx:id="txtGenereFilm" promptText="Es. Fantascienza" />
                        </VBox>
                        <VBox spacing="5">
                            <Label text="Durata (min)" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                            <TextField fx:id="txtDurataFilm" promptText="Es. 169" />
                        </VBox>
                        <VBox spacing="5">
                            <Label text="Descrizione" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                            <TextArea fx:id="txtDescrizioneFilm" prefRowCount="4" wrapText="true" />
                        </VBox>
                        <Button maxWidth="Infinity" onAction="#handleAggiungiFilm" styleClass="button-primary" text="Salva nel Catalogo" />
                    </VBox>

                    <VBox spacing="15.0" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);">
                        <Label styleClass="label-subtitle" text="Film Disponibili" />
                        <TableView fx:id="filmTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colIdFilm" prefWidth="40" text="ID" />
                                <TableColumn fx:id="colTitoloFilm" text="Titolo" />
                                <TableColumn fx:id="colGenereFilm" text="Genere" />
                                <TableColumn fx:id="colDurataFilm" text="Durata" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                        <HBox alignment="CENTER_RIGHT">
                            <Button onAction="#handleRimuoviFilm" styleClass="button-danger" text="Elimina Film Selezionato" />
                        </HBox>
                    </VBox>
                </HBox>
            </Tab>

            <Tab text="Utenti e Manager">
                <HBox spacing="20.0">
                    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

                    <VBox prefWidth="320.0" spacing="20.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);">
                        <Label styleClass="label-subtitle" text="Assegna Ruolo Manager" />

                        <VBox spacing="5">
                            <Label style="-fx-text-fill: #7f8c8d; -fx-font-weight: bold; -fx-font-size: 11px;" text="1. UTENTE SELEZIONATO" />
                            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #F5F6FA; -fx-padding: 10; -fx-background-radius: 5;">
                                <Label fx:id="lblUtenteSelezionato" text="Nessuno" textFill="#2980b9" style="-fx-font-weight: bold;"/>
                            </HBox>
                        </VBox>

                        <VBox spacing="5">
                            <Label style="-fx-text-fill: #7f8c8d; -fx-font-weight: bold; -fx-font-size: 11px;" text="2. CINEMA DI DESTINAZIONE" />
                            <ComboBox fx:id="cmbCinemaManager" maxWidth="Infinity" promptText="Scegli Cinema..." style="-fx-font-size: 14px;"/>
                        </VBox>

                        <VBox VBox.vgrow="ALWAYS" />

                        <Button maxWidth="Infinity" onAction="#handlePromuoviManager" styleClass="button-primary" text="Conferma Nomina" />
                        <Label wrapText="true" text="Nota: L'utente diventerà gestore esclusivo del cinema selezionato." textFill="#95a5a6" style="-fx-font-size: 11px; -fx-font-style: italic;"/>
                    </VBox>

                    <VBox HBox.hgrow="ALWAYS" spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);">
                        <Label styleClass="label-subtitle" text="Registro Utenti" />
                        <TableView fx:id="utentiTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colNomeUtente" text="Nome" />
                                <TableColumn fx:id="colCognomeUtente" text="Cognome" />
                                <TableColumn fx:id="colEmailUtente" text="Email" />
                                <TableColumn fx:id="colRuoloUtente" text="Ruolo Attuale" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                    </VBox>
                </HBox>
            </Tab>

            <Tab text="Statistiche Globali">
                <VBox alignment="CENTER" spacing="30.0">
                    <padding><Insets bottom="50" left="50" right="50" top="50" /></padding>

                    <Label styleClass="label-title" text="Riepilogo Finanziario Network" />

                    <HBox alignment="CENTER" spacing="50.0">
                        <VBox alignment="CENTER" prefWidth="320" prefHeight="220" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 0);">
                            <Label style="-fx-font-size: 20px; -fx-text-fill: #7f8c8d;" text="Incasso Totale" />
                            <Label fx:id="lblIncassiTotali" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" text="€ 0.00" />
                        </VBox>

                        <VBox alignment="CENTER" prefWidth="320" prefHeight="220" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 0);">
                            <Label style="-fx-font-size: 20px; -fx-text-fill: #7f8c8d;" text="Biglietti Venduti" />
                            <Label fx:id="lblBigliettiTotali" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #2980b9;" text="0" />
                        </VBox>
                    </HBox>

                    <Button onAction="#initialize" styleClass="button-neutral" text="Aggiorna Dati" />
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>