<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" styleClass="root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.ticketflow.ui.controller.UserDashboardController">

    <top>
        <VBox spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="navbar">
                <padding>
                    <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
                </padding>
                <children>
                    <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="TicketFlow" />
                    <Label style="-fx-text-fill: #bdc3c7; -fx-font-size: 16px;" text="|  Programmazione Cinema" />
                    <HBox HBox.hgrow="ALWAYS" />

                    <Button onAction="#handleLogout" styleClass="button-danger" text="Esci" />
                </children>
            </HBox>

            <HBox alignment="CENTER" spacing="15.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 2); -fx-padding: 20;">
                <children>
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 14px;" text="Cerca Spettacolo:" />

                    <TextField fx:id="searchField" prefWidth="300.0" promptText="Titolo del film..." style="-fx-font-size: 13px;" />
                    <ComboBox fx:id="genreComboBox" prefWidth="180.0" promptText="Tutti i Generi" style="-fx-font-size: 13px;" />
                    <DatePicker fx:id="datePicker" promptText="Data" prefWidth="150.0" style="-fx-font-size: 13px;" />

                    <Button onAction="#handleSearch" styleClass="button-primary" text="Applica Filtri" />
                    <Button onAction="#handleReset" styleClass="button-neutral" text="Reset" />
                </children>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" vbarPolicy="AS_NEEDED">
            <content>
                <TilePane fx:id="spettacoliContainer" hgap="25.0" prefColumns="4" style="-fx-background-color: transparent;" vgap="25.0">
                    <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
                    </padding>
                </TilePane>
            </content>
        </ScrollPane>
    </center>

</BorderPane>