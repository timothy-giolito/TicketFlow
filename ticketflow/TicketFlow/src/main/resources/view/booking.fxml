<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.ticketflow.ui.controller.BookingController"
            prefHeight="600.0" prefWidth="800.0">

    <top>
        <VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #2c3e50; -fx-padding: 20;">
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Button fx:id="btnIndietro" text="← Indietro"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 5; -fx-cursor: hand;"/>

                <Label fx:id="lblTitoloSpettacolo" text="Caricamento..." textFill="WHITE"
                       style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            </HBox>

            <Label text="SCHERMO" textFill="#bdc3c7"
                   style="-fx-border-color: #bdc3c7; -fx-border-width: 0 0 5 0; -fx-padding: 0 50 5 50; -fx-font-size: 14px;"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent;">
            <content>
                <GridPane fx:id="grigliaPosti" alignment="CENTER" hgap="10" vgap="10"
                          style="-fx-padding: 30; -fx-background-color: #ecf0f1;">
                </GridPane>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <VBox alignment="CENTER" spacing="20.0" style="-fx-padding: 20; -fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-width: 1 0 0 0;">

            <HBox alignment="CENTER" spacing="15.0">
                <Label text="Dati Pagamento:" style="-fx-font-weight: bold;"/>
                <TextField fx:id="txtNumeroCarta" promptText="Numero Carta (16 cifre)" prefWidth="200"/>
                <TextField fx:id="txtScadenza" promptText="MM/YY" prefWidth="70"/>
                <TextField fx:id="txtCVV" promptText="CVV" prefWidth="50"/>
            </HBox>

            <HBox alignment="CENTER" spacing="30.0">
                <HBox spacing="10" alignment="CENTER">
                    <Label text="■ Libero" style="-fx-text-fill: #1dd1a1; -fx-font-weight: bold;"/>
                    <Label text="■ Occupato" style="-fx-text-fill: #ff6b6b; -fx-font-weight: bold;"/>
                    <Label text="■ Selezionato" style="-fx-text-fill: #feca57; -fx-font-weight: bold;"/>
                </HBox>

                <Button fx:id="btnConferma" text="Conferma (0)"
                        onAction="#handlePaga"
                        disable="true"
                        style="-fx-background-color: #0984e3; -fx-text-fill: white; -fx-font-size: 16px; -fx-cursor: hand; -fx-padding: 10 30;"/>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>